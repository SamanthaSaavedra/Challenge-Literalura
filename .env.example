# ============================================================
# VARIABLES DE ENTORNO - LiteraLura
# ============================================================
# Copia este archivo como ".env" y rellena tus valores reales.
# NUNCA subas el archivo .env a tu repositorio Git.
# ============================================================

# URL de conexión a PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/literalura

# Usuario de PostgreSQL
DB_USERNAME=tu_usuario

# Contraseña de PostgreSQL
DB_PASSWORD=tu_contraseña

# (Opcional) URL de la API Gutendex - por defecto usa la pública
GUTENDEX_URL=https://gutendex.com/books/
